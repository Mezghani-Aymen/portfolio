{
    "compilerOptions": {
        "typeRoots": [
            "./node_modules/@types",
            "./src/@types" 
        ],
        "moduleResolution": "node",
        "target": "es6",
        "module": "commonjs",
        "jsx": "react",
        "strict": true,
        "esModuleInterop": true, // Ensure this is set to true
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "allowJs": true,
        "baseUrl": "src",
        "paths": {
            "lib/*": [
                "lib/*"
            ]
        }
    },
    "include": [
        "src/**/*",
        "lib/**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}